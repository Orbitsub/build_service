# Build Service — Environment Variables
# Copy this file to .env and fill in the values.
# This file must never be committed to source control.

# Flask session signing key — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# WARNING: changing this value invalidates all active user sessions.
FLASK_SECRET=replace_with_a_long_random_hex_string
